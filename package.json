{
  "name": "modmanager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b && vite build --config packages/app/vite.config.ts",
    "build:ts": "tsc -b",
    "clean": "rimraf packages/*/dist",
    "dev": "concurrently -k -n VITE,ELECTRON \"vite --config packages/app/vite.config.ts --host 127.0.0.1 --port 5178\" \"wait-on tcp:127.0.0.1:5178 && tsc -b && cross-env NODE_ENV=development VITE_DEV_SERVER_URL=http://127.0.0.1:5178 electron packages/app/dist/main.js\"",
    "typecheck": "tsc -b --pretty false"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.15.3",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  }
}
