{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true,
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    "types": [
      "node",
      "vite/client"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts"
  ],
  "references": [
    {
      "path": "../types"
    },
    {
      "path": "../logger"
    },
    {
      "path": "../fs"
    },
    {
      "path": "../security"
    },
    {
      "path": "../core"
    },
    {
      "path": "../ipc"
    },
    {
      "path": "../ui"
    }
  ]
}
