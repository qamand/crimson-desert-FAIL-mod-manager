{
  "name": "@modmanager/app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -b",
    "build:renderer": "vite build",
    "dev": "concurrently -k -n VITE,ELECTRON \"vite --host 127.0.0.1 --port 5178\" \"wait-on tcp:127.0.0.1:5178 && tsc -b ../.. && cross-env NODE_ENV=development VITE_DEV_SERVER_URL=http://127.0.0.1:5178 electron dist/main.js\"",
    "dev:main": "wait-on tcp:127.0.0.1:5178 && tsc -b ../.. && cross-env NODE_ENV=development VITE_DEV_SERVER_URL=http://127.0.0.1:5178 electron dist/main.js",
    "dev:renderer": "vite --host 127.0.0.1 --port 5178",
    "dist": "tsc -b && vite build && electron-builder --config electron-builder.yml"
  },
  "dependencies": {
    "@modmanager/core": "workspace:*",
    "@modmanager/fs": "workspace:*",
    "@modmanager/ipc": "workspace:*",
    "@modmanager/logger": "workspace:*",
    "@modmanager/security": "workspace:*",
    "@modmanager/ui": "workspace:*",
    "@modmanager/papgt": "workspace:*",
    "electron-updater": "^6.6.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  },
  "build": {
    "extends": "./electron-builder.yml"
  }
}